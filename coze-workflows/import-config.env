# Coze 导入配置文件
# 
# 请填写以下信息后保存此文件
# 然后运行: node scripts/quick-import.js

# ============================================
# API配置
# ============================================

# Coze API Key
# 获取方法：登录 https://www.coze.cn → 右上角头像 → API管理
COZE_API_KEY=your_api_key_here

# Bot ID
# 获取方法：创建Bot后，从URL中获取
# URL格式: https://www.coze.cn/bot/YOUR_BOT_ID
BOT_ID=your_bot_id_here

# ============================================
# 可选配置
# ============================================

# 是否创建新Bot（如果为true，将忽略BOT_ID）
CREATE_NEW_BOT=false

# 新Bot名称（如果CREATE_NEW_BOT=true）
NEW_BOT_NAME=文献Meta分析助手

# API基础地址（一般不需要修改）
COZE_API_BASE=https://api.coze.cn/v1
