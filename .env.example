# ===========================================
# 支付系统配置
# ===========================================

# 管理员密钥（用于管理后台登录）
# 请修改为你自己的复杂密码
ADMIN_KEY=your-admin-key-change-this

# Webhook 密钥（用于验证支付通知请求）
# 请修改为你自己的密钥
PAYMENT_WEBHOOK_KEY=your-webhook-key-change-this

# 定时任务密钥（用于验证定时任务请求）
CRON_KEY=your-cron-key-change-this

# ===========================================
# 应用配置
# ===========================================

# 应用域名（部署后修改为实际域名）
NEXT_PUBLIC_APP_URL=http://localhost:5000

# ===========================================
# 数据库配置（Supabase）
# ===========================================

# Supabase 项目 URL
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url

# Supabase 匿名密钥
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase 服务端密钥
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ===========================================
# 可选：第三方支付平台
# ===========================================

# 虎皮椒支付（如使用）
# HUPIJIAO_APPID=your-appid
# HUPIJIAO_APPSECRET=your-appsecret

# 免签支付（如使用）
# MIANQIAN_PID=your-pid
# MIANQIAN_KEY=your-key
# MIANQIAN_PLATFORM=mfk

# XorPay（如使用）
# XORPAY_APP_ID=your-app-id
# XORPAY_APP_SECRET=your-app-secret
